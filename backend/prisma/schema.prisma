generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CLIENT
}

enum TourType {
  NACIONAL
  INTERNACIONAL
}

enum TourStatus {
  ACTIVO
  INACTIVO
}

enum ReservationStatus {
  PENDIENTE
  PAGADA
  RECHAZADA
  CANCELADA
}

enum PaymentMethod {
  CARD
  YAPE
}

enum PaymentStatus {
  PENDIENTE
  EXITOSO
  RECHAZADO
  DEVUELTO
}

enum Currency {
  PEN
  USD
}

enum PaymentMode {
  FULL
  DEPOSIT
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(120)
  email     String   @unique @db.VarChar(120)
  password  String   @db.VarChar(255)
  role      Role     @default(CLIENT)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model Category {
  id    Int    @id @default(autoincrement())
  name  String @db.VarChar(100)
  tours Tour[]

  @@map("categories")
}

model Tour {
  id             Int          @id @default(autoincrement())
  categoryId     Int?         @map("category_id")
  title          String       @db.VarChar(150)
  slug           String       @unique @db.VarChar(160)
  destination    String       @db.VarChar(120)
  description    String?      @db.Text
  price          Decimal      @db.Decimal(10, 2)
  currency       Currency     @default(PEN)
  paymentMode    PaymentMode  @default(FULL) @map("payment_mode")
  depositPercent Int?         @map("deposit_percent")
  duration       String?      @db.VarChar(80)
  type           TourType
  availableSlots Int          @default(0) @map("available_slots")
  imageUrl       String?      @map("image_url") @db.Text
  imageCredit    String?      @map("image_credit") @db.VarChar(255)
  isFeatured     Boolean      @default(false) @map("is_featured")
  status         TourStatus   @default(ACTIVO)
  itinerary      Json?
  includes       Json?
  excludes       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  category       Category?    @relation(fields: [categoryId], references: [id])
  images         TourImage[]
  reservations   Reservation[]
  departures     TourDeparture[]

  @@map("tours")
}

model TourDeparture {
  id             Int           @id @default(autoincrement())
  tourId         Int           @map("tour_id")
  startDate      DateTime      @map("start_date") @db.Date
  endDate        DateTime?     @map("end_date") @db.Date
  capacity       Int
  availableSlots Int           @map("available_slots")
  status         TourStatus    @default(ACTIVO)
  tour           Tour          @relation(fields: [tourId], references: [id], onDelete: Cascade)
  reservations   Reservation[]

  @@unique([tourId, startDate])
  @@map("tour_departures")
}

model TourImage {
  id        Int    @id @default(autoincrement())
  tourId    Int    @map("tour_id")
  imageUrl  String @map("image_url") @db.Text
  altText   String? @map("alt_text") @db.VarChar(180)
  tour      Tour   @relation(fields: [tourId], references: [id], onDelete: Cascade)

  @@map("tour_images")
}

model Customer {
  id             Int           @id @default(autoincrement())
  fullName       String        @map("full_name") @db.VarChar(120)
  email          String        @db.VarChar(120)
  phone          String?       @db.VarChar(30)
  documentNumber String?       @map("document_number") @db.VarChar(30)
  createdAt      DateTime      @default(now()) @map("created_at")
  reservations   Reservation[]

  @@map("customers")
}

model Reservation {
  id          Int               @id @default(autoincrement())
  customerId  Int               @map("customer_id")
  tourId      Int               @map("tour_id")
  departureId Int?              @map("departure_id")
  travelDate  DateTime          @map("travel_date") @db.Date
  peopleCount Int               @map("people_count")
  totalAmount Decimal           @map("total_amount") @db.Decimal(10, 2)
  status      ReservationStatus @default(PENDIENTE)
  createdAt   DateTime          @default(now()) @map("created_at")
  customer    Customer          @relation(fields: [customerId], references: [id])
  tour        Tour              @relation(fields: [tourId], references: [id])
  departure   TourDeparture?    @relation(fields: [departureId], references: [id])
  payments    Payment[]

  @@map("reservations")
}

model Payment {
  id             Int           @id @default(autoincrement())
  reservationId  Int           @map("reservation_id")
  culqiChargeId  String?       @map("culqi_charge_id") @db.VarChar(150)
  paymentMethod  PaymentMethod @map("payment_method")
  amount         Decimal       @db.Decimal(10, 2)
  currency       String        @default("PEN") @db.VarChar(10)
  status         PaymentStatus @default(PENDIENTE)
  culqiResponse  Json?         @map("culqi_response")
  createdAt      DateTime      @default(now()) @map("created_at")
  reservation    Reservation   @relation(fields: [reservationId], references: [id])

  @@map("payments")
}

model ContactMessage {
  id        Int      @id @default(autoincrement())
  fullName  String   @map("full_name") @db.VarChar(120)
  email     String   @db.VarChar(120)
  phone     String?  @db.VarChar(30)
  message   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("contact_messages")
}

model Testimonial {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(120)
  location  String?  @db.VarChar(120)
  comment   String   @db.Text
  rating    Int      @default(5)
  avatarUrl String?  @map("avatar_url") @db.Text
  source    String?  @db.VarChar(255)
  verified  Boolean  @default(false)
  published Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("testimonials")
}


model BusinessSettings {
  id                 Int      @id @default(1)
  legalName          String?  @map("legal_name") @db.VarChar(180)
  tradeName          String   @default("Jhon Tours") @map("trade_name") @db.VarChar(120)
  taxId              String?  @map("tax_id") @db.VarChar(30)
  address            String?  @db.VarChar(255)
  supportEmail       String?  @map("support_email") @db.VarChar(120)
  whatsappNumber     String?  @map("whatsapp_number") @db.VarChar(30)
  domain             String?  @db.VarChar(180)
  cancellationPolicy String?  @map("cancellation_policy") @db.LongText
  refundPolicy       String?  @map("refund_policy") @db.LongText
  terms              String?  @db.LongText
  privacyPolicy      String?  @map("privacy_policy") @db.LongText
  cookiePolicy       String?  @map("cookie_policy") @db.LongText
  complaintsBookUrl  String?  @map("complaints_book_url") @db.Text
  policiesPublished  Boolean  @default(false) @map("policies_published")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("business_settings")
}
